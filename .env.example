# ============================================================
# API Keys - pick ONE provider, the system auto-detects which
# ============================================================

# Option 1: Google Gemini (RECOMMENDED for teammates - FREE!)
# Get free key at: https://aistudio.google.com/apikey
# Limits: 1500 queries/day, no credit card required
# GOOGLE_API_KEY=your_gemini_api_key_here

# Option 2: OpenAI (best quality, costs ~$2-5)
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Option 3: Anthropic Claude (good quality, costs vary)
# Get key at: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================================
# Vector Store
# ============================================================
VECTOR_STORE_TYPE=chroma
VECTOR_STORE_PATH=./data/chroma

# ============================================================
# Embedding Model (huggingface = FREE, local)
# ============================================================
EMBEDDING_MODEL=huggingface
# EMBEDDING_MODEL=openai

# ============================================================
# LLM Model - matches your API key choice above
# ============================================================
# For Gemini (FREE): use gemini-1.5-flash or gemini-1.5-pro
# LLM_MODEL=gemini-1.5-flash

# For OpenAI:
LLM_MODEL=gpt-4o-mini

# For Anthropic:
# LLM_MODEL=claude-3-haiku-20240307

# ============================================================
# Server
# ============================================================
SERVER_PORT=8001
SERVER_HOST=127.0.0.1

# Debug
DEBUG=False
